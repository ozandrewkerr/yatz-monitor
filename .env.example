# Copy this file to ".env" and fill in your values, then run ./monitor.sh
# NEVER commit .env (it's git-ignored). On GitHub these go in repo Secrets.

# --- Your Taronga YATZ / VicNet login ---
YATZ_EMAIL=you@example.com
YATZ_PASSWORD=your-vicnet-password

# --- Telegram bot (from @BotFather) ---
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# --- Optional ---
# MONTHS_AHEAD=3                 # scan current month + this many ahead
# DRY_RUN=1                      # print instead of sending (for testing)
